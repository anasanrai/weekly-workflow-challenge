      "name": "Format Weather Data"
    },
    {
      "parameters": {
        "jsCode": "// Get data from the nodes that fed into this merge point\nconst allInputs = $input.all();\n\n// Get tasks from Format Tasks Data\nconst tasks = $('Format Tasks Data').all().map(i => i.json);\n\n// Get emails from Format Gmail Data  \nconst emails = $('Format Gmail Data').all().map(i => i.json);\n\n// Get events from Format Calendar Data\nconst events = $('Format Calendar Data').all().map(i => i.json);\n\n// Get weather\nconst weather = $('Format Weather Data').first().json;\n\nconst overdue = tasks.filter(t => t.due_date && t.due_date < new Date().toISOString().split('T')[0]);\nconst highPriority = tasks.filter(t => t.priority === 'urgent' || t.priority === 'high');\nconst financeEmails = emails.filter(e => e.category === 'Finance');\nconst urgentEmails = emails.filter(e => e.category === 'High Priority');\n\nconst prompt = `You are a business intelligence assistant. Generate a structured daily briefing.\n\nWEATHER: ${weather.temp}°C, ${weather.description} in ${weather.city}\n\nTODAY'S SCHEDULE (${events.length} events):\n${events.map(e => `- ${e.start_time}: ${e.title}`).join('\\n')}\n\nTASKS SUMMARY:\n- Total open: ${tasks.length}\n- Overdue: ${overdue.length}\n- High priority: ${highPriority.length}\n${overdue.map(t => `- OVERDUE: ${t.name} (was due ${t.due_date})`).join('\\n')}\n${highPriority.slice(0,3).map(t => `- HIGH: ${t.name} (due ${t.due_date || 'no date'})`).join('\\n')}\n\nEMAILS (${emails.length} unread):\n- Finance: ${financeEmails.length}\n- High Priority: ${urgentEmails.length}\n${urgentEmails.map(e => `- URGENT: ${e.subject} from ${e.from}`).join('\\n')}\n${financeEmails.map(e => `- FINANCE: ${e.subject}`).join('\\n')}\n\nWrite exactly 4 sections:\n1. WEATHER & DAY CONTEXT\n2. SCHEDULE TODAY\n3. TASKS & PRIORITIES\n4. EMAILS & ALERTS\n\nRules: Plain text only. No markdown. No ** or ##. Max 2 sentences per section.`;\n\nreturn [{ json: { payload: JSON.stringify({\n  model: \"claude-haiku-4-5-20251001\",\n  max_tokens: 600,\n  messages: [{ role: \"user\", content: prompt }]\n})}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
