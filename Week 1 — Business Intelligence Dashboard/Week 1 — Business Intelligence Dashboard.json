    {
      "parameters": {
        "jsCode": "const emails = $input.all().map(i => i.json);\n\nconst formatted = emails.map(email => {\n  // Debug — find where from/subject actually live\n  const from = email.From || email.from || email.headers?.from || '';\n  const subject = email.Subject || email.subject || email.headers?.subject || '';\n  \n  const cleanSnippet = (email.snippet || '')\n    .replace(/[\\u034F\\u200B-\\u200D\\uFEFF\\u00AD\\u034F]/g, '')\n    .replace(/\\s+/g, ' ')\n    .trim()\n    .substring(0, 150);\n\n  const allLabels = (email.labels || []).map(l => l.name || l);\n  const importantLabels = allLabels.filter(l => \n    !['INBOX','UNREAD','IMPORTANT','CATEGORY_UPDATES','CATEGORY_PROMOTIONS','CATEGORY_SOCIAL'].includes(l)\n  );\n\n  const subjectLower = subject.toLowerCase();\n  const isFinance = importantLabels.some(l => l.toLowerCase().includes('financ') || l.toLowerCase().includes('bill')) ||\n    subjectLower.includes('invoice') || subjectLower.includes('receipt') || subjectLower.includes('payment');\n\n  const isHighPriority = importantLabels.some(l => l.toLowerCase().includes('priority')) ||\n    subjectLower.includes('urgent') || subjectLower.includes('cancelled') || subjectLower.includes('paused');\n\n  return {\n    id: email.id,\n    from,\n    subject,\n    snippet: cleanSnippet,\n    date: email.date || new Date().toISOString().split('T')[0],\n    category: isFinance ? 'Finance' : isHighPriority ? 'High Priority' : 'Updates',\n    labels: importantLabels\n  };\n});\n\nreturn formatted.map(email => ({ json: email }));"
      },
