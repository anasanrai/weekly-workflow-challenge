      "parameters": {
        "jsCode": "const response = $('Generate AI Summary').first().json.content[0].text;\nconst weather = $('Format Weather Data').first().json;\nconst events = $('Format Calendar Data').all().map(i => i.json);\nconst today = new Date().toDateString();\n\nconst sections = response.split('\\n').filter(l => l.trim());\n\nconst message = `📊 <b>Daily Business Briefing</b>\n🗓 <i>${today}</i>\n─────────────────────\n\n🌤 <b>${weather.temp}°C — ${weather.description} in ${weather.city}</b>\n\n📅 <b>Today's Schedule</b>\n${events.map(e => `• ${e.start_time} — ${e.title}`).join('\\n')}\n\n─────────────────────\n${response}\n─────────────────────\n<i>Powered by BridgeFlow x Claude AI</i>`;\n\nreturn [{\n  json: {\n    payload: JSON.stringify({\n      chat_id: \"YOUR_TELEGRAM_CHAT_ID\",\n      text: message,\n      parse_mode: \"HTML\"\n    })\n  }\n}];"
